-- NO RECOIL — méthode correcte via BindToRenderStep
-- ============================================================
-- On mémorise le CFrame de la caméra AVANT que le moteur applique le recul
-- puis on le restaure si la différence de pitch est positive (recul vers le haut)
local savedCamCF  = nil
local noRecoilBound = false

local function BindNoRecoil()
    if noRecoilBound then return end
    noRecoilBound = true

    -- Priorité Camera (avant rendu) : on sauvegarde
    RunService:BindToRenderStep("AR2_NR_SAVE", Enum.RenderPriority.Camera.Value - 1, function()
        if Config.NoRecoil_Enabled then
            savedCamCF = Camera.CFrame
        end
    end)

    -- Priorité Last (après que le jeu a appliqué le recul) : on corrige
    RunService:BindToRenderStep("AR2_NR_FIX", Enum.RenderPriority.Last.Value, function()
        if not Config.NoRecoil_Enabled or not savedCamCF then return end

        -- Vérifie qu'on tient une arme
        local char = LocalPlayer.Character
        local hasTool = false
        if char then
            for _, obj in pairs(char:GetChildren()) do
                if obj:IsA("Tool") then hasTool = true break end
            end
        end
        if not hasTool then savedCamCF = nil return end

        local newCF     = Camera.CFrame
        local oldPitch  = select(1, savedCamCF:ToEulerAnglesYXZ())
        local newPitch  = select(1, newCF:ToEulerAnglesYXZ())
        local _, newYaw = select(2, newCF:ToEulerAnglesYXZ()), select(2, newCF:ToEulerAnglesYXZ())
        local _, _, newRoll = newCF:ToEulerAnglesYXZ()

        -- Le recul fait monter la visée = pitch diminue (plus négatif)
        -- On annule seulement les changements involontaires de pitch
        local pitchDelta = newPitch - oldPitch
        if pitchDelta < -0.0005 then
            -- Restaurer le pitch d'avant, garder yaw & position actuels
            local _, savedYaw, savedRoll = savedCamCF:ToEulerAnglesYXZ()
            -- On garde la position et le yaw courant, on restaure juste le pitch
            local _, curYaw, _ = newCF:ToEulerAnglesYXZ()
            Camera.CFrame = CFrame.new(newCF.Position)
                * CFrame.fromEulerAnglesYXZ(oldPitch, curYaw, newRoll)
        end
    end)
end
BindNoRecoil()


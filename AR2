        if cb then cb(state) end
    end)
end

-- Slider générique
local function Slider(label, minVal, maxVal, defaultVal, cb)
    local container = Instance.new("Frame", ContentFrame)
    container.Size = UDim2.new(1, 0, 0, 52)
    container.BackgroundColor3 = Color3.fromRGB(19, 19, 25)
    container.BorderSizePixel = 0
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 7)

    local titleLbl = Instance.new("TextLabel", container)
    titleLbl.Size = UDim2.new(1, -10, 0, 20)
    titleLbl.Position = UDim2.new(0, 12, 0, 4)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = label .. " : " .. defaultVal
    titleLbl.TextColor3 = Color3.fromRGB(210, 210, 210)
    titleLbl.TextSize = 12
    titleLbl.Font = Enum.Font.Gotham
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left

    local trackBg = Instance.new("Frame", container)
    trackBg.Size = UDim2.new(1, -24, 0, 6)
    trackBg.Position = UDim2.new(0, 12, 1, -18)
    trackBg.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    trackBg.BorderSizePixel = 0
    Instance.new("UICorner", trackBg).CornerRadius = UDim.new(1, 0)

    local pct = (defaultVal - minVal) / (maxVal - minVal)
    local fill = Instance.new("Frame", trackBg)
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(200, 30, 30)
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local handle = Instance.new("Frame", trackBg)
    handle.Size = UDim2.new(0, 14, 0, 14)
    handle.Position = UDim2.new(pct, -7, 0.5, -7)
    handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    handle.BorderSizePixel = 0
    Instance.new("UICorner", handle).CornerRadius = UDim.new(1, 0)

    local currentVal = defaultVal
    local sliding = false

    local function UpdateSlider(absX)
        local trackAbsPos = trackBg.AbsolutePosition.X
        local trackAbsSize = trackBg.AbsoluteSize.X
        local p = math.clamp((absX - trackAbsPos) / trackAbsSize, 0, 1)
        fill.Size = UDim2.new(p, 0, 1, 0)
        handle.Position = UDim2.new(p, -7, 0.5, -7)
        currentVal = math.floor(minVal + p * (maxVal - minVal))
        titleLbl.Text = label .. " : " .. currentVal
        if cb then cb(currentVal) end
    end

    trackBg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
            UpdateSlider(i.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateSlider(i.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)

    return container
end


local function HPColor(pct)
    if pct > 0.6 then return Color3.fromRGB(50, 220, 80)
    elseif pct > 0.3 then return Color3.fromRGB(240, 180, 30)
    else return Color3.fromRGB(240, 50, 50) end
end

local function GetWeaponLabel(char)
    -- Chercher Tool directement sur le character (arme équipée)
    for _, obj in pairs(char:GetChildren()) do
        if obj:IsA("Tool") then
            local name = obj.Name
            local info = AR2_WEAPONS[name]
            if info then
                return info.icon .. " " .. name .. "  [" .. info.cat .. "]"
            else
                -- Arme inconnue : affiche quand même
                return "🔫 " .. name
            end
        end
    end
    -- Aucun outil → chercher un Model nommé comme une arme (certains jeux cachent l'arme ainsi)
    for _, obj in pairs(char:GetChildren()) do
        if obj:IsA("Model") then
            local info = AR2_WEAPONS[obj.Name]
            if info then return info.icon .. " " .. obj.Name .. "  [" .. info.cat .. "]" end
        end
    end
    return "✋ Aucun"
end


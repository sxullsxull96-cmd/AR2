-- ESP OBJECTS
-- ============================================================
local ESPObjects = {}

local function CreateESP(player)
    if player == LocalPlayer then return end
    if ESPObjects[player] then return end
    local data = {}

    -- Highlight travers murs
    local hl
    local ok = pcall(function()
        hl = Instance.new("Highlight")
        hl.FillColor          = Color3.fromRGB(255, 30, 30)
        hl.OutlineColor       = Color3.fromRGB(255, 130, 130)
        hl.FillTransparency   = 0.5
        hl.OutlineTransparency = 0
        hl.DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop
    end)
    if not ok then
        hl = Instance.new("SelectionBox")
        hl.Color3 = Color3.fromRGB(255,30,30)
        hl.LineThickness = 0.05
        hl.SurfaceTransparency = 0.55
        hl.SurfaceColor3 = Color3.fromRGB(255,30,30)
    end

    -- Billboard
    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(0, 220, 0, 90)
    bb.StudsOffset = Vector3.new(0, 4, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = Config.MaxDistance
    bb.ResetOnSpawn = false

    -- Nom
    local nameLbl = Instance.new("TextLabel", bb)
    nameLbl.Size = UDim2.new(1,0,0,18)
    nameLbl.BackgroundTransparency = 1
    nameLbl.TextColor3 = Color3.fromRGB(255,80,80)
    nameLbl.TextSize = Config.TextSize + 1
    nameLbl.Font = Enum.Font.GothamBold
    nameLbl.TextStrokeTransparency = 0.3
    nameLbl.TextStrokeColor3 = Color3.fromRGB(0,0,0)

    -- HP bar background
    local hpBg = Instance.new("Frame", bb)
    hpBg.Size = UDim2.new(0.85, 0, 0, 7)
    hpBg.Position = UDim2.new(0.075, 0, 0, 22)
    hpBg.BackgroundColor3 = Color3.fromRGB(35,35,35)
    hpBg.BorderSizePixel = 0
    Instance.new("UICorner", hpBg).CornerRadius = UDim.new(1, 0)

    -- HP bar fill
    local hpFill = Instance.new("Frame", hpBg)
    hpFill.Size = UDim2.new(1, 0, 1, 0)
    hpFill.BackgroundColor3 = Color3.fromRGB(50,220,80)
    hpFill.BorderSizePixel = 0
    Instance.new("UICorner", hpFill).CornerRadius = UDim.new(1, 0)

    -- HP texte
    local hpTxt = Instance.new("TextLabel", bb)
    hpTxt.Size = UDim2.new(1,0,0,13)
    hpTxt.Position = UDim2.new(0,0,0,32)
    hpTxt.BackgroundTransparency = 1
    hpTxt.TextColor3 = Color3.fromRGB(200,200,200)
    hpTxt.TextSize = 11
    hpTxt.Font = Enum.Font.Gotham
    hpTxt.TextStrokeTransparency = 0.4
    hpTxt.TextStrokeColor3 = Color3.fromRGB(0,0,0)

    -- Distance
    local distLbl = Instance.new("TextLabel", bb)
    distLbl.Size = UDim2.new(1,0,0,16)
    distLbl.Position = UDim2.new(0,0,0,48)
    distLbl.BackgroundTransparency = 1
    distLbl.TextColor3 = Color3.fromRGB(255,200,200)
    distLbl.TextSize = Config.TextSize
    distLbl.Font = Enum.Font.Gotham
    distLbl.TextStrokeTransparency = 0.4
    distLbl.TextStrokeColor3 = Color3.fromRGB(0,0,0)

    -- Arme
    local itemLbl = Instance.new("TextLabel", bb)
    itemLbl.Size = UDim2.new(1,0,0,16)
    itemLbl.Position = UDim2.new(0,0,0,66)
    itemLbl.BackgroundTransparency = 1
    itemLbl.TextColor3 = Color3.fromRGB(255,240,100)
    itemLbl.TextSize = Config.TextSize - 1
    itemLbl.Font = Enum.Font.Gotham
    itemLbl.TextStrokeTransparency = 0.4
    itemLbl.TextStrokeColor3 = Color3.fromRGB(0,0,0)

    data.hl       = hl
    data.bb       = bb
    data.nameLbl  = nameLbl
    data.hpBg     = hpBg
    data.hpFill   = hpFill
    data.hpTxt    = hpTxt
    data.distLbl  = distLbl
    data.itemLbl  = itemLbl

    -- HP listener : connecte l'event Changed de la Humanoid pour réagir instantanément
    -- (fonctionne côté client même sans permissions serveur)
    data.hpConn = nil

    ESPObjects[player] = data
end

local function RemoveESP(player)
    if ESPObjects[player] then
        local d = ESPObjects[player]
        if d.hpConn then d.hpConn:Disconnect() end
        pcall(function() d.hl:Destroy() end)
        pcall(function() d.bb:Destroy() end)
        ESPObjects[player] = nil
    end
    if RadarDots[player] then
        pcall(function() RadarDots[player]:Destroy() end)
        RadarDots[player] = nil
    end
end

local function GetRadarDot(player)
    if RadarDots[player] then return RadarDots[player] end
    local dot = Instance.new("Frame", RadarFrame)
    dot.Size = UDim2.new(0,7,0,7)
    dot.BackgroundColor3 = Color3.fromRGB(255,50,50)
    dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
    RadarDots[player] = dot
    return dot
end

-- ============================================================
-- SPEED : réappliquer au respawn
-- ============================================================
local function ApplySpeed(char)
    if not Config.Speed_Enabled then return end
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.WalkSpeed = 16 * Config.SpeedMultiplier end
end
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    ApplySpeed(char)
end)

-- ============================================================
-- MAIN UPDATE LOOP
-- ============================================================
RunService.RenderStepped:Connect(function()
    local localChar = LocalPlayer.Character
    local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")
    local localCF   = localRoot and localRoot.CFrame

    -- Speed persistant
    if Config.Speed_Enabled and localChar then
        local hum = localChar:FindFirstChildOfClass("Humanoid")
        if hum and math.abs(hum.WalkSpeed - 16 * Config.SpeedMultiplier) > 0.5 then
            hum.WalkSpeed = 16 * Config.SpeedMultiplier
        end
    end

    RadarFrame.Visible = Config.Radar_Enabled

    if not Config.ESP_Enabled then
        statusLabel.Text = "ESP INACTIF"
        statusLabel.TextColor3 = Color3.fromRGB(100, 100, 100)
        for _, d in pairs(ESPObjects) do
            if d.hl:IsA("Highlight") then d.hl.Enabled = false
            else d.hl.Adornee = nil end
            d.bb.Enabled = false
        end
        for _, dot in pairs(RadarDots) do
            if not Config.Radar_Enabled then dot.Visible = false end
        end
    else
        statusLabel.Text = "ESP ACTIF — " .. (#Players:GetPlayers()-1) .. " joueur(s)"
        statusLabel.TextColor3 = Color3.fromRGB(200, 50, 50)
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        CreateESP(player)
        local d = ESPObjects[player]
        if not d then continue end

        local char = player.Character
        if not char then
            if d.hl:IsA("Highlight") then d.hl.Enabled = false else d.hl.Adornee = nil end
            d.bb.Enabled = false
            if RadarDots[player] then RadarDots[player].Visible = false end
            continue
        end

        local root = char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not root or not hum or hum.Health <= 0 then
            if d.hl:IsA("Highlight") then d.hl.Enabled = false else d.hl.Adornee = nil end
            d.bb.Enabled = false
            if RadarDots[player] then RadarDots[player].Visible = false end
            continue
        end

        local dist = localRoot and math.floor((root.Position - localRoot.Position).Magnitude) or 0

        -- Connecter le listener HP si pas encore fait (réaction instantanée aux dégâts/heal)
        if not d.hpConn then
            d.hpConn = hum:GetPropertyChangedSignal("Health"):Connect(function()
                -- Mise à jour immédiate quand Health change (dégâts OU heal)
                if not d.hpBg then return end
                local pct = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
                d.hpFill.Size = UDim2.new(pct, 0, 1, 0)
                d.hpFill.BackgroundColor3 = HPColor(pct)
                d.hpTxt.Text = math.floor(hum.Health) .. " / " .. math.floor(hum.MaxHealth)
                d.hpTxt.TextColor3 = HPColor(pct)
            end)
        end

        -- ── HIGHLIGHT
        if Config.ESP_Highlight and Config.ESP_Enabled then
            if d.hl:IsA("Highlight") then
                d.hl.Adornee = char
                d.hl.Enabled = true
                if not d.hl.Parent then d.hl.Parent = CoreGui end
            else
                d.hl.Adornee = char
                if not d.hl.Parent then d.hl.Parent = CoreGui end
            end
        else
            if d.hl:IsA("Highlight") then d.hl.Enabled = false
            else d.hl.Adornee = nil end
        end

        -- ── BILLBOARD
        if Config.ESP_Enabled then
            d.bb.Enabled = true
            d.bb.MaxDistance = Config.MaxDistance
            if not d.bb.Parent then d.bb.Parent = root end

            d.nameLbl.Text = "⚠ " .. player.Name

            -- HP (aussi mis à jour via listener, mais on sync ici aussi)
            d.hpBg.Visible = Config.ESP_Health
            d.hpTxt.Visible = Config.ESP_Health
            if Config.ESP_Health then
                local pct = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
                d.hpFill.Size = UDim2.new(pct, 0, 1, 0)
                d.hpFill.BackgroundColor3 = HPColor(pct)
                d.hpTxt.Text = math.floor(hum.Health) .. " / " .. math.floor(hum.MaxHealth)
                d.hpTxt.TextColor3 = HPColor(pct)
            end

            -- Distance
            d.distLbl.Visible = Config.ESP_Distance
            if Config.ESP_Distance then
                d.distLbl.Text = "📍 " .. dist .. " m"
            end

            -- Arme
            d.itemLbl.Visible = Config.ESP_Item
            if Config.ESP_Item then
                d.itemLbl.Text = GetWeaponLabel(char)
            end
        else
            d.bb.Enabled = false
        end

        -- ── RADAR
        if Config.Radar_Enabled and localRoot and localCF then
            local dot = GetRadarDot(player)
            local rel   = localCF:PointToObjectSpace(root.Position)
            local rSize = RadarFrame.AbsoluteSize
            local scale = (rSize.X / 2) / Config.RadarRange
            local rx = 0.5 + (-rel.X * scale) / rSize.X
            local ry = 0.5 + (-rel.Z * scale) / rSize.Y
            dot.Position = UDim2.new(math.clamp(rx,0,1), -3, math.clamp(ry,0,1), -3)
            dot.Visible  = (dist <= Config.RadarRange * 1.5)
        else
            if RadarDots[player] then RadarDots[player].Visible = false end
        end
    end
end)

